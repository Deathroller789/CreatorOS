# --- Python / uv ---
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# --- Node (only if a local install ever happens; MCP servers run via npx cache) ---
node_modules/

# --- Environments & secrets ---
.env
.env.*
*.key
*.pem

# --- Caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- SQLite ---
# Volatile side-files are ALWAYS ignored (never meaningful to track).
*.db-wal
*.db-shm
*.db-journal
*.sqlite3-journal
# NOTE: whether the main SQLite DB file is committed is an open architectural decision
# (source-of-truth vs. runtime state), to be settled in a SQLite ADR. For the MVP we
# treat it as runtime state and do not commit it.
database/*.db
database/*.sqlite3

# --- Local run outputs ---
screenshot.png
/output/

# --- Claude Code (keep .claude/ tracked; ignore only machine-local settings) ---
.claude/settings.local.json

# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/
